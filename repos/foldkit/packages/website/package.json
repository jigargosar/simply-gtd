{
  "name": "website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter foldkit run docs",
    "dev": "vite",
    "prebuild": "pnpm --filter foldkit run docs",
    "build": "vite build",
    "preview": "vite preview",
    "pretypecheck": "pnpm --filter foldkit run docs",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "prerender": "tsx scripts/prerender.ts",
    "postprerender": "pagefind",
    "preview:search": "pnpm build && pnpm prerender && vite preview"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.88",
    "@foldkit/devtools": "workspace:*",
    "@foldkit/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@webcontainer/api": "^1.6.4",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.88",
    "foldkit": "workspace:*",
    "monaco-editor": "^0.55.1",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.88",
    "@foldkit/vite-plugin": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.4",
    "pagefind": "^1.5.2",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "satori": "^0.26.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
