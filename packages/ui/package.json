{
  "name": "@foldkit/ui",
  "version": "0.117.0",
  "description": "Headless, accessible UI components for Foldkit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./animation": {
      "types": "./dist/animation/public.d.ts",
      "import": "./dist/animation/public.js"
    },
    "./button": {
      "types": "./dist/button/public.d.ts",
      "import": "./dist/button/public.js"
    },
    "./calendar": {
      "types": "./dist/calendar/public.d.ts",
      "import": "./dist/calendar/public.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox/public.d.ts",
      "import": "./dist/checkbox/public.js"
    },
    "./combobox": {
      "types": "./dist/combobox/public.d.ts",
      "import": "./dist/combobox/public.js"
    },
    "./datePicker": {
      "types": "./dist/datePicker/public.d.ts",
      "import": "./dist/datePicker/public.js"
    },
    "./dialog": {
      "types": "./dist/dialog/public.d.ts",
      "import": "./dist/dialog/public.js"
    },
    "./disclosure": {
      "types": "./dist/disclosure/public.d.ts",
      "import": "./dist/disclosure/public.js"
    },
    "./dragAndDrop": {
      "types": "./dist/dragAndDrop/public.d.ts",
      "import": "./dist/dragAndDrop/public.js"
    },
    "./fieldset": {
      "types": "./dist/fieldset/public.d.ts",
      "import": "./dist/fieldset/public.js"
    },
    "./fileDrop": {
      "types": "./dist/fileDrop/public.d.ts",
      "import": "./dist/fileDrop/public.js"
    },
    "./input": {
      "types": "./dist/input/public.d.ts",
      "import": "./dist/input/public.js"
    },
    "./listbox": {
      "types": "./dist/listbox/public.d.ts",
      "import": "./dist/listbox/public.js"
    },
    "./menu": {
      "types": "./dist/menu/public.d.ts",
      "import": "./dist/menu/public.js"
    },
    "./popover": {
      "types": "./dist/popover/public.d.ts",
      "import": "./dist/popover/public.js"
    },
    "./radioGroup": {
      "types": "./dist/radioGroup/public.d.ts",
      "import": "./dist/radioGroup/public.js"
    },
    "./select": {
      "types": "./dist/select/public.d.ts",
      "import": "./dist/select/public.js"
    },
    "./slider": {
      "types": "./dist/slider/public.d.ts",
      "import": "./dist/slider/public.js"
    },
    "./switch": {
      "types": "./dist/switch/public.d.ts",
      "import": "./dist/switch/public.js"
    },
    "./tabs": {
      "types": "./dist/tabs/public.d.ts",
      "import": "./dist/tabs/public.js"
    },
    "./textarea": {
      "types": "./dist/textarea/public.d.ts",
      "import": "./dist/textarea/public.js"
    },
    "./toast": {
      "types": "./dist/toast/public.d.ts",
      "import": "./dist/toast/public.js"
    },
    "./tooltip": {
      "types": "./dist/tooltip/public.d.ts",
      "import": "./dist/tooltip/public.js"
    },
    "./virtualList": {
      "types": "./dist/virtualList/public.d.ts",
      "import": "./dist/virtualList/public.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "pnpm run clean && tsc -b tsconfig.build.json",
    "watch": "tsc -b tsconfig.build.json --watch",
    "lint": "pnpm --filter @foldkit/oxlint-plugin build && oxlint src",
    "typecheck": "tsc -b tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.88",
    "foldkit": "workspace:^0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.88",
    "effect": "4.0.0-beta.88",
    "foldkit": "workspace:*",
    "happy-dom": "^20.10.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "foldkit",
    "ui",
    "components",
    "headless",
    "accessible"
  ],
  "author": "Devin Jameson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foldkit/foldkit.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
